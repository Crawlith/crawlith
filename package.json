{
  "name": "crawlith",
  "type": "module",
  "private": true,
  "description": "Professional-grade SEO crawling and graph intelligence suite.",
  "bin": {
    "crawlith": "packages/cli/dist/index.js"
  },
  "scripts": {
    "build": "pnpm --filter \"./packages/**\" build",
    "test": "pnpm --filter @crawlith/core test && pnpm --filter @crawlith/cli test",
    "lint": "eslint .",
    "crawlith": "node packages/cli/dist/index.js",
    "rebuild": "find . -name 'node_modules' -type d -prune -exec rm -rf '{}' + && find . -name 'dist' -type d -prune -exec rm -rf '{}' + && pnpm install && pnpm build",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "npm run build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.8",
    "@eslint/js": "^10.0.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.12.7",
    "@types/update-notifier": "^6.0.8",
    "@typescript-eslint/eslint-plugin": "^8.56.0",
    "@typescript-eslint/parser": "^8.56.0",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^10.0.0",
    "rimraf": "^5.0.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5",
    "typescript-eslint": "^8.56.0",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "update-notifier": "^7.3.1",
    "vite": "7.3.1"
  }
}